      "name": "3. SMS COMMANDES (JWT)",
      "item": [
        {
          "name": "3.1 SOLDE? Hermann",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Script JWT pour générer le token d'authentification",
                  "const secret = pm.variables.get('jwt_secret');",
                  "const body = JSON.parse(pm.request.body.raw);",
                  "",
                  "// Fonction Base64URL",
                  "function base64url(source) {",
                  "    let enc = source.toString(CryptoJS.enc.Base64);",
                  "    enc = enc.split('=').join('').split('+').join('-').split('/').join('_');",
                  "    return enc;",
                  "}",
                  "",
                  "// Header JWT",
                  "const header = { alg: 'HS256', typ: 'JWT' };",
                  "const encodedHeader = base64url(CryptoJS.enc.Utf8.parse(JSON.stringify(header)));",
                  "",
                  "// Payload JWT avec claims",
                  "const now = Math.floor(Date.now() / 1000);",
                  "const exp = now + 3600; // 1 heure",
                  "",
                  "// Hash SHA-256 du body (16 premiers caractères hex)",
                  "const bodyHashFull = CryptoJS.SHA256(body.body).toString(CryptoJS.enc.Hex);",
                  "const bodyHash = bodyHashFull.substring(0, 16);",
                  "",
                  "const payload = {",
                  "    sub: 'sms-webhook',",
                  "    iat: now,",
                  "    exp: exp,",
                  "    from: body.from,",
                  "    to: body.to,",
                  "    bodyHash: bodyHash",
                  "};",
                  "const encodedPayload = base64url(CryptoJS.enc.Utf8.parse(JSON.stringify(payload)));",
                  "",
                  "// Signature HMAC-SHA256",
                  "const signature = CryptoJS.HmacSHA256(encodedHeader + '.' + encodedPayload, secret);",
                  "const encodedSignature = base64url(signature);",
                  "",
                  "// Token JWT final",
                  "const jwt = encodedHeader + '.' + encodedPayload + '.' + encodedSignature;",
                  "",
                  "// Nettoyer les anciens headers et ajouter le Bearer token",
                  "pm.request.headers.remove('Authorization');",
                  "pm.request.headers.remove('X-Webhook-Timestamp');",
                  "pm.request.headers.remove('X-Webhook-Signature');",
                  "pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + jwt });",
                  "",
                  "console.log('JWT Token généré:', jwt);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"from\": \"+22890000001\",\n    \"to\": \"+22801010101\",\n    \"body\": \"SOLDE?\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/sms/webhook" }
          }
        },
