    {
      "name": "1. SOLDE - Tous les comptes",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "X-API-Key", "value": "ORABANK_2024_SECURE_WEBHOOK_KEY_12345"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"from\":\"+22890000001\",\"to\":\"ORABANK\",\"body\":\"SOLDE\"}"
        },
        "url": {
          "raw": "https://sms-banking-pjcp.onrender.com/api/sms/webhook"
        }
